<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CraftCart.Pages.SellerDashboardPage"
             Title="SellerDashboardPage"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" BackgroundColor="#2E5E3F" Padding="20,12" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                <Label Text="&#x1F6D2;" FontSize="22" VerticalOptions="Center"/>
                <Label Text="CraftCart" FontSize="20" TextColor="White" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>
            <Label Grid.Column="2" Text="Dashboard" TextColor="White" FontAttributes="Bold" FontSize="14" VerticalOptions="Center" Margin="10,0"/>
            <Label Grid.Column="3" Text="My Products" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0"/>
            <Label Grid.Column="4" Text="Orders" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0"/>
            <Label Grid.Column="5" Text="Account" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="30,20" Spacing="20">

                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="Seller Dashboard" FontSize="26" FontAttributes="Bold"/>
                        <Label Text="Welcome back, ArtStudio" TextColor="Gray" FontSize="13"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="+ Add New Product" BackgroundColor="#2E5E3F" TextColor="White"
                            CornerRadius="8" Padding="20,10" FontSize="13" VerticalOptions="Center"/>
                </Grid>

                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="15">
                    <Border Grid.Column="0" BackgroundColor="#E8F5E9" StrokeShape="RoundRectangle 10" Padding="20" Stroke="Transparent">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                            <Label Text="$1,260" FontSize="24" FontAttributes="Bold" TextColor="#2E7D32" HorizontalOptions="Center"/>
                            <Label Text="Total Revenue" FontSize="12" TextColor="#555" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="#E3F2FD" StrokeShape="RoundRectangle 10" Padding="20" Stroke="Transparent">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                            <Label Text="25" FontSize="24" FontAttributes="Bold" TextColor="#1565C0" HorizontalOptions="Center"/>
                            <Label Text="Total Orders" FontSize="12" TextColor="#555" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="#FFF3E0" StrokeShape="RoundRectangle 10" Padding="20" Stroke="Transparent">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                            <Label Text="3" FontSize="24" FontAttributes="Bold" TextColor="#E65100" HorizontalOptions="Center"/>
                            <Label Text="Active Listings" FontSize="12" TextColor="#555" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="3" BackgroundColor="#FCE4EC" StrokeShape="RoundRectangle 10" Padding="20" Stroke="Transparent">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                            <Label Text="4.8" FontSize="24" FontAttributes="Bold" TextColor="#C62828" HorizontalOptions="Center"/>
                            <Label Text="Avg Rating" FontSize="12" TextColor="#555" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Label Text="My Listings" FontAttributes="Bold" FontSize="18"/>

                <Grid ColumnDefinitions="2*,*,*,*,*" Padding="15,10" BackgroundColor="#F5F5F5">
                    <Label Grid.Column="0" Text="Product" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                    <Label Grid.Column="1" Text="Price" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                    <Label Grid.Column="2" Text="Sold" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                    <Label Grid.Column="3" Text="Revenue" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                    <Label Grid.Column="4" Text="Status" FontAttributes="Bold" FontSize="13" TextColor="#555"/>
                </Grid>

                <Grid ColumnDefinitions="2*,*,*,*,*" Padding="15,12">
                    <HorizontalStackLayout Grid.Column="0" Spacing="10">
                        <Border BackgroundColor="#E8F5E9" StrokeShape="RoundRectangle 6" WidthRequest="35" HeightRequest="35" Stroke="Transparent">
                            <Label Text="&#x1F3FA;" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Ceramic Vase" FontSize="13" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Grid.Column="1" Text="$45.00" FontSize="13" VerticalOptions="Center"/>
                    <Label Grid.Column="2" Text="12" FontSize="13" VerticalOptions="Center"/>
                    <Label Grid.Column="3" Text="$540" FontSize="13" TextColor="#2E7D32" VerticalOptions="Center"/>
                    <Border Grid.Column="4" BackgroundColor="#E8F5E9" StrokeShape="RoundRectangle 10" Padding="10,3"
                            Stroke="Transparent" VerticalOptions="Center" HorizontalOptions="Start">
                        <Label Text="Active" TextColor="#2E7D32" FontSize="11"/>
                    </Border>
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="#F0F0F0"/>

                <Grid ColumnDefinitions="2*,*,*,*,*" Padding="15,12">
                    <HorizontalStackLayout Grid.Column="0" Spacing="10">
                        <Border BackgroundColor="#FFF3E0" StrokeShape="RoundRectangle 6" WidthRequest="35" HeightRequest="35" Stroke="Transparent">
                            <Label Text="&#x1FAD6;" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Clay Teapot" FontSize="13" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Grid.Column="1" Text="$60.00" FontSize="13" VerticalOptions="Center"/>
                    <Label Grid.Column="2" Text="8" FontSize="13" VerticalOptions="Center"/>
                    <Label Grid.Column="3" Text="$480" FontSize="13" TextColor="#2E7D32" VerticalOptions="Center"/>
                    <Border Grid.Column="4" BackgroundColor="#E8F5E9" StrokeShape="RoundRectangle 10" Padding="10,3"
                            Stroke="Transparent" VerticalOptions="Center" HorizontalOptions="Start">
                        <Label Text="Active" TextColor="#2E7D32" FontSize="11"/>
                    </Border>
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="#F0F0F0"/>

                <Grid ColumnDefinitions="2*,*,*,*,*" Padding="15,12">
                    <HorizontalStackLayout Grid.Column="0" Spacing="10">
                        <Border BackgroundColor="#E3F2FD" StrokeShape="RoundRectangle 6" WidthRequest="35" HeightRequest="35" Stroke="Transparent">
                            <Label Text="&#x1F3B6;" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Mini Bottle Set" FontSize="13" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Grid.Column="1" Text="$30.00" FontSize="13" VerticalOptions="Center"/>
                    <Label Grid.Column="2" Text="5" FontSize="13" VerticalOptions="Center"/>
                    <Label Grid.Column="3" Text="$150" FontSize="13" TextColor="#2E7D32" VerticalOptions="Center"/>
                    <Border Grid.Column="4" BackgroundColor="#E8F5E9" StrokeShape="RoundRectangle 10" Padding="10,3"
                            Stroke="Transparent" VerticalOptions="Center" HorizontalOptions="Start">
                        <Label Text="Active" TextColor="#2E7D32" FontSize="11"/>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
