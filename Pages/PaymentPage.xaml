<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CraftCart.Pages.PaymentPage"
             Title="PaymentPage"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" BackgroundColor="#2E5E3F" Padding="20,12" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                <Label Text="&#x1F6D2;" FontSize="22" VerticalOptions="Center"/>
                <Label Text="CraftCart" FontSize="20" TextColor="White" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>
            <Label Grid.Column="2" Text="Browse" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBrowseTapped"/>
                </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="3" Text="My Cart" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCartTapped"/>
                </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="4" Text="Orders" TextColor="White" FontAttributes="Bold" FontSize="14" VerticalOptions="Center" Margin="10,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOrdersTapped"/>
                </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="5" Text="Account" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAccountTapped"/>
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <ScrollView Grid.Row="1">
            <Grid ColumnDefinitions="1.5*,*" Padding="30,25" ColumnSpacing="30">

                <VerticalStackLayout Grid.Column="0" Spacing="12">

                    <Label Text="Payment Information" FontSize="24" FontAttributes="Bold"/>
                    <Label Text="Enter your card details to complete the purchase" TextColor="Gray" FontSize="13" Margin="0,0,0,10"/>

                    <Border BackgroundColor="#2E5E3F" StrokeShape="RoundRectangle 14" Padding="25,20"
                            HeightRequest="180" Stroke="Transparent" Margin="0,0,0,10">
                        <Grid RowDefinitions="Auto,*,Auto,Auto">
                            <HorizontalStackLayout Grid.Row="0">
                                <Label Text="CREDIT CARD" TextColor="#AAD4AA" FontSize="11" FontAttributes="Bold"/>
                                <Label Text="    &#x1F4B3;" FontSize="20" HorizontalOptions="EndAndExpand"/>
                            </HorizontalStackLayout>
                            <Label x:Name="CardNumberPreviewLabel" Grid.Row="1"
                                   Text="&#x2022;&#x2022;&#x2022;&#x2022;  &#x2022;&#x2022;&#x2022;&#x2022;  &#x2022;&#x2022;&#x2022;&#x2022;  &#x2022;&#x2022;&#x2022;&#x2022;"
                                   TextColor="White" FontSize="20" VerticalOptions="Center"/>
                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                <VerticalStackLayout>
                                    <Label Text="CARD HOLDER" TextColor="#AAD4AA" FontSize="9"/>
                                    <Label x:Name="CardholderPreviewLabel" Text="YOUR NAME" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="EXPIRES" TextColor="#AAD4AA" FontSize="9"/>
                                    <Label x:Name="ExpiryPreviewLabel" Text="MM/YY" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>

                    <Label Text="Cardholder Name" FontAttributes="Bold" FontSize="13"/>
                    <Entry x:Name="CardholderEntry" Placeholder="John Doe" FontSize="14"
                           TextChanged="OnCardholderChanged"/>

                    <Label Text="Card Number" FontAttributes="Bold" FontSize="13"/>
                    <Entry x:Name="CardNumberEntry" Placeholder="4242 4242 4242 4242" FontSize="14"
                           Keyboard="Numeric" TextChanged="OnCardNumberChanged"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Expiry Date" FontAttributes="Bold" FontSize="13"/>
                            <Entry x:Name="ExpiryEntry" Placeholder="MM/YY" FontSize="14"
                                   TextChanged="OnExpiryChanged"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="CVV" FontAttributes="Bold" FontSize="13"/>
                            <Entry x:Name="CvvEntry" Placeholder="***" FontSize="14" IsPassword="True"
                                   Keyboard="Numeric"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Button Text="Confirm and Pay" BackgroundColor="#2E5E3F" TextColor="White" CornerRadius="8"
                            Padding="20,10" FontSize="14" HorizontalOptions="Start" Margin="0,10,0,0"
                            Clicked="OnPayClicked"/>

                    <Label x:Name="ErrorLabel" TextColor="Red"/>

                </VerticalStackLayout>

                <Border Grid.Column="1" Stroke="#E8E8E8" StrokeShape="RoundRectangle 10" Padding="25" VerticalOptions="Start">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Order Summary" FontAttributes="Bold" FontSize="18"/>

                        <CollectionView x:Name="SummaryCollection">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="0,4">
                                        <Border BackgroundColor="#E8F5E9" StrokeShape="RoundRectangle 6" WidthRequest="40" HeightRequest="40" Stroke="Transparent">
                                            <Grid>
                                                <Label Text="&#x1F4E6;" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                <Image Source="{Binding Image}" Aspect="AspectFill"/>
                                            </Grid>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding ProductName}" FontAttributes="Bold" FontSize="13"/>
                                            <Label Text="{Binding Quantity, StringFormat='x{0}'}" TextColor="Gray" FontSize="11"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding Price, StringFormat='${0:F2}'}" FontSize="13" VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,5"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Subtotal:" FontSize="13" TextColor="#555"/>
                            <Label x:Name="SubtotalLabel" Grid.Column="1" FontSize="13"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Tax:" FontSize="13" TextColor="#555"/>
                            <Label x:Name="TaxLabel" Grid.Column="1" FontSize="13"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Shipping:" FontSize="13" TextColor="#555"/>
                            <Label x:Name="ShippingLabel" Grid.Column="1" FontSize="13"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,3"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Total:" FontAttributes="Bold" FontSize="16"/>
                            <Label x:Name="TotalLabel" Grid.Column="1" FontAttributes="Bold" FontSize="16" TextColor="#2E5E3F"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </Grid>
        </ScrollView>

    </Grid>

</ContentPage>
