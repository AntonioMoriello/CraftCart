<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CraftCart.Pages.ResetPasswordPage"
             Title="ResetPasswordPage">

    <Grid ColumnDefinitions="*,2*">

        <Grid Grid.Column="0" BackgroundColor="#2E5E3F">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="5">
                <Label Text="&#x1F6D2;"
                       FontSize="60"
                       HorizontalOptions="Center"/>
                <Label Text="CraftCart"
                       FontSize="35"
                       TextColor="White"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Text="Handmade, delivered to you"
                       FontSize="14"
                       TextColor="#C8D6C8"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="40" Spacing="10">

                <Label Text="Reset Password"
                       FontSize="32"
                       FontAttributes="Bold"/>

                <Label Text="Please enter your email address to receive the reset link"
                       TextColor="Gray"/>

                <Label Text="Email"
                       FontAttributes="Bold"
                       Margin="0,20,0,0"/>
                <Entry x:Name="EmailEntry"
                       Placeholder="Email"/>

                <Button Text="Submit"
                        BackgroundColor="#2E5E3F"
                        TextColor="White"
                        CornerRadius="5"
                        HorizontalOptions="Start"
                        WidthRequest="120"
                        Clicked="OnSubmitClicked"/>

                <HorizontalStackLayout Spacing="5">
                    <Label Text="Remember your password?"
                           VerticalOptions="Center"
                           TextColor="Gray"/>
                    <Label Text="Sign in here"
                           TextColor="Blue"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGoToSignInPage"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <Label x:Name="result"
                       TextColor="Red"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
