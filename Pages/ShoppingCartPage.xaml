<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CraftCart.Pages.ShoppingCartPage"
             Title="ShoppingCartPage"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" BackgroundColor="#2E5E3F" Padding="20,12" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                <Label Text="&#x1F6D2;" FontSize="22" VerticalOptions="Center"/>
                <Label Text="CraftCart" FontSize="20" TextColor="White" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>
            <Label Grid.Column="2" Text="Browse" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBrowseTapped"/>
                </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="3" Text="My Cart" TextColor="White" FontAttributes="Bold" FontSize="14" VerticalOptions="Center" Margin="10,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCartTapped"/>
                </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="4" Text="Orders" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOrdersTapped"/>
                </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="5" Text="Account" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAccountTapped"/>
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <ScrollView Grid.Row="1">
            <Grid ColumnDefinitions="1.5*,*" Padding="30,20" ColumnSpacing="30">

                <VerticalStackLayout Grid.Column="0" Spacing="10">

                    <Label Text="My Cart" FontSize="26" FontAttributes="Bold"/>
                    <Label x:Name="ItemCountLabel" TextColor="Gray" FontSize="13" Margin="0,0,0,10"/>

                    <CollectionView x:Name="CartCollection">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#E8E8E8" StrokeShape="RoundRectangle 10" Padding="15" Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="15">
                                        <Border Grid.Column="0" BackgroundColor="#E8F5E9" StrokeShape="RoundRectangle 8"
                                                WidthRequest="60" HeightRequest="60" Stroke="Transparent">
                                            <Label Text="&#x1F4E6;" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding ProductName}" FontAttributes="Bold" FontSize="14"/>
                                        </VerticalStackLayout>
                                        <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                            <Button Text="-" FontSize="14" Padding="8,4" BackgroundColor="White" TextColor="Black"
                                                    BorderColor="#CCC" BorderWidth="1" CornerRadius="4"
                                                    Clicked="OnMinusClicked" WidthRequest="35" HeightRequest="35"/>
                                            <Label Text="{Binding Quantity}" FontSize="14" VerticalOptions="Center"/>
                                            <Button Text="+" FontSize="14" Padding="8,4" BackgroundColor="White" TextColor="Black"
                                                    BorderColor="#CCC" BorderWidth="1" CornerRadius="4"
                                                    Clicked="OnPlusClicked" WidthRequest="35" HeightRequest="35"/>
                                        </HorizontalStackLayout>
                                        <Label Grid.Column="3" Text="{Binding Price, StringFormat='${0:F2}'}" FontAttributes="Bold" FontSize="15" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label x:Name="EmptyLabel" Text="Your cart is empty" TextColor="Gray" FontSize="14" HorizontalOptions="Center" IsVisible="False"/>

                </VerticalStackLayout>

                <Border Grid.Column="1" Stroke="#E8E8E8" StrokeShape="RoundRectangle 10" Padding="25" VerticalOptions="Start">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Order Summary" FontAttributes="Bold" FontSize="18"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Subtotal:" FontSize="14" TextColor="#555"/>
                            <Label x:Name="SubtotalLabel" Grid.Column="1" FontSize="14"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Tax (GST):" FontSize="14" TextColor="#555"/>
                            <Label x:Name="TaxLabel" Grid.Column="1" FontSize="14"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Shipping:" FontSize="14" TextColor="#555"/>
                            <Label x:Name="ShippingLabel" Grid.Column="1" FontSize="14"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,5"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Total:" FontAttributes="Bold" FontSize="16"/>
                            <Label x:Name="TotalLabel" Grid.Column="1" FontAttributes="Bold" FontSize="16" TextColor="#2E5E3F"/>
                        </Grid>

                        <Button Text="Checkout" BackgroundColor="#2E5E3F" TextColor="White" CornerRadius="8"
                                FontSize="15" Margin="0,10,0,0" Clicked="OnCheckoutClicked"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>
        </ScrollView>

    </Grid>

</ContentPage>
