<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CraftCart.Pages.ProductDetailPage"
             Title="ProductDetailPage"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" BackgroundColor="#2E5E3F" Padding="20,12" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                <Label Text="&#x1F6D2;" FontSize="22" VerticalOptions="Center"/>
                <Label Text="CraftCart" FontSize="20" TextColor="White" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>
            <Label Grid.Column="2" Text="Browse" TextColor="White" FontAttributes="Bold" FontSize="14" VerticalOptions="Center" Margin="10,0"/>
            <Label Grid.Column="3" Text="My Cart" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0"/>
            <Label Grid.Column="4" Text="Orders" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0"/>
            <Label Grid.Column="5" Text="Account" TextColor="#C8D6C8" FontSize="14" VerticalOptions="Center" Margin="10,0"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <Grid ColumnDefinitions="*,1.5*" Padding="40,30" ColumnSpacing="40">

                <Border Grid.Column="0" BackgroundColor="#E8F5E9" StrokeShape="RoundRectangle 12" Stroke="#E0E0E0"
                        HeightRequest="350" VerticalOptions="Start">
                    <Grid>
                        <Label x:Name="ImagePlaceholder" Text="&#x1F3FA;" FontSize="80"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Image x:Name="ProductImage" Aspect="AspectFill" IsVisible="False"/>
                    </Grid>
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="8">

                    <Label x:Name="ProductNameLabel" FontSize="28" FontAttributes="Bold"/>
                    <Label x:Name="SellerNameLabel" TextColor="Gray" FontSize="14"/>

                    <HorizontalStackLayout Spacing="5">
                        <Label x:Name="RatingStarsLabel" FontSize="14" TextColor="#F5A623"/>
                        <Label x:Name="ReviewCountLabel" TextColor="#2E5E3F" FontSize="13"/>
                    </HorizontalStackLayout>

                    <Label x:Name="ProductPriceLabel" FontSize="26" FontAttributes="Bold" TextColor="#2E5E3F" Margin="0,5,0,0"/>

                    <Label x:Name="ProductDescriptionLabel" TextColor="#555" FontSize="14" Margin="0,10,0,0"/>

                    <HorizontalStackLayout x:Name="TagsLayout" Spacing="8" Margin="0,10,0,0"/>

                    <HorizontalStackLayout Spacing="12" Margin="0,15,0,0">
                        <Button Text="Add to Cart &#x1F6D2;" BackgroundColor="#2E5E3F" TextColor="White" CornerRadius="8"
                                Padding="20,10" FontSize="14" Clicked="OnAddToCartClicked"/>
                        <Button Text="View Seller" BackgroundColor="White" TextColor="#2E5E3F" BorderColor="#2E5E3F"
                                BorderWidth="1" CornerRadius="8" Padding="20,10" FontSize="14"/>
                    </HorizontalStackLayout>

                    <Label Text="Reviews" FontAttributes="Bold" FontSize="16" Margin="0,20,0,5"/>

                    <CollectionView x:Name="ReviewsCollection">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#E0E0E0" StrokeShape="RoundRectangle 8" Padding="15,10" WidthRequest="180">
                                    <VerticalStackLayout Spacing="3">
                                        <Label Text="{Binding Rating, StringFormat='Rating: {0}/5'}" FontSize="11" TextColor="#F5A623"/>
                                        <Label Text="{Binding Comment}" FontSize="12" TextColor="#555"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>

            </Grid>
        </ScrollView>

    </Grid>

</ContentPage>
